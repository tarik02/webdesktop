[Unit]
Description=Webdesktop remote desktop service
Requisite=graphical-session.target
Wants=xdg-desktop-portal.service plasma-xdg-desktop-portal-kde.service
After=graphical-session.target xdg-desktop-portal.service plasma-xdg-desktop-portal-kde.service
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=@webdesktop@/bin/webdesktop serve --config %h/.config/webdesktop/config.yaml
Restart=no
TimeoutStopSec=15s
UMask=0077

[Install]
WantedBy=graphical-session.target
